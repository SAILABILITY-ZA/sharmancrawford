<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sharman Crawford Lodge No. 608 — Cape Town</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Cinzel:wght@400;600&family=Lato:wght@300;400&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #c9a84c;
    --gold-light: #e8c97a;
    --gold-dim: #7a6330;
    --dark: #0a0905;
    --deep: #12100a;
    --mid: #1e1a12;
    --surface: #241f15;
    --text: #e8e0d0;
    --text-dim: #9a9080;
    --irish-green: #1a4a2e;
    --irish-green-light: #2a7a4a;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background-color: var(--dark);
    color: var(--text);
    font-family: 'Lato', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
  }

  /* ---- GRAIN OVERLAY ---- */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.35;
  }

  /* ---- NAV ---- */
  nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 100;
    padding: 1.4rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: linear-gradient(to bottom, rgba(10,9,5,0.95) 0%, transparent 100%);
    backdrop-filter: blur(2px);
  }

  .nav-brand {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    color: var(--gold);
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }

  .nav-links a {
    font-family: 'Lato', sans-serif;
    font-weight: 300;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.3s;
  }

  .nav-links a:hover { color: var(--gold); }

  /* ---- HERO ---- */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    position: relative;
    padding: 8rem 2rem 4rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 60% at 50% 40%, rgba(201,168,76,0.07) 0%, transparent 70%),
      radial-gradient(ellipse 40% 80% at 20% 50%, rgba(26,74,46,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 40% 80% at 80% 50%, rgba(26,74,46,0.06) 0%, transparent 60%),
      linear-gradient(180deg, #0a0905 0%, #12100a 100%);
  }

  .compass-rose {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    opacity: 0.04;
    animation: slowRotate 120s linear infinite;
  }

  @keyframes slowRotate {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  .lodge-emblem {
    position: relative;
    width: 220px;
    height: 100px;
    margin-bottom: 3rem;
    animation: fadeUp 1.2s ease forwards;
    opacity: 0;
  }

  .lodge-emblem svg { width: 100%; height: 100%; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-eyebrow {
    font-family: 'Cinzel', serif;
    font-size: 0.65rem;
    letter-spacing: 0.4em;
    color: var(--gold-dim);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    position: relative;
    animation: fadeUp 1.2s 0.2s ease forwards;
    opacity: 0;
  }

  .hero-eyebrow::before,
  .hero-eyebrow::after {
    content: '—';
    margin: 0 1rem;
    color: var(--gold-dim);
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    line-height: 1.05;
    letter-spacing: 0.02em;
    color: var(--text);
    margin-bottom: 0.5rem;
    position: relative;
    animation: fadeUp 1.2s 0.35s ease forwards;
    opacity: 0;
  }

  .hero-title em {
    font-style: italic;
    color: var(--gold);
  }

  .hero-number {
    font-family: 'Cinzel', serif;
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    color: var(--gold-dim);
    margin-bottom: 2.5rem;
    animation: fadeUp 1.2s 0.5s ease forwards;
    opacity: 0;
  }

  .hero-divider {
    width: 1px;
    height: 80px;
    background: linear-gradient(to bottom, transparent, var(--gold), transparent);
    margin: 0 auto 2.5rem;
    animation: fadeUp 1.2s 0.65s ease forwards;
    opacity: 0;
  }

  .hero-tagline {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    color: var(--text-dim);
    max-width: 640px;
    line-height: 1.7;
    animation: fadeUp 1.2s 0.8s ease forwards;
    opacity: 0;
    position: relative;
  }

  .hero-cta {
    margin-top: 3.5rem;
    animation: fadeUp 1.2s 1s ease forwards;
    opacity: 0;
    position: relative;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.9rem 2.8rem;
    border: 1px solid var(--gold);
    color: var(--gold);
    font-family: 'Cinzel', serif;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.4s;
    position: relative;
    overflow: hidden;
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--gold);
    transform: translateX(-100%);
    transition: transform 0.4s;
  }

  .btn-primary:hover { color: var(--dark); }
  .btn-primary:hover::before { transform: translateX(0); }
  .btn-primary span { position: relative; z-index: 1; }

  .scroll-indicator {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    animation: fadeUp 1.2s 1.3s ease forwards;
    opacity: 0;
  }

  .scroll-indicator span {
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    color: var(--text-dim);
    text-transform: uppercase;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--gold-dim), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.2); }
  }

  /* ---- SECTIONS ---- */
  section { padding: 7rem 2rem; position: relative; }

  .container { max-width: 1100px; margin: 0 auto; }

  .section-label {
    font-family: 'Cinzel', serif;
    font-size: 0.6rem;
    letter-spacing: 0.4em;
    color: var(--gold-dim);
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--gold-dim), transparent);
    max-width: 80px;
  }

  /* ---- PHILOSOPHY ---- */
  .philosophy {
    background: var(--deep);
  }

  .philosophy-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .philosophy-text h2 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.2;
    margin-bottom: 2rem;
    color: var(--text);
  }

  .philosophy-text h2 em {
    font-style: italic;
    color: var(--gold);
  }

  .philosophy-text p {
    font-size: 0.95rem;
    line-height: 1.9;
    color: var(--text-dim);
    margin-bottom: 1.4rem;
  }

  .harari-quote {
    border-left: 2px solid var(--gold);
    padding: 1.5rem 2rem;
    margin: 2.5rem 0;
    background: rgba(201,168,76,0.04);
  }

  .harari-quote blockquote {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--text);
    margin-bottom: 0.8rem;
  }

  .harari-quote cite {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold-dim);
  }

  .pillars {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .pillar {
    padding: 2rem;
    border: 1px solid rgba(201,168,76,0.15);
    background: rgba(201,168,76,0.02);
    position: relative;
    transition: border-color 0.3s, background 0.3s;
  }

  .pillar:hover {
    border-color: rgba(201,168,76,0.4);
    background: rgba(201,168,76,0.05);
  }

  .pillar-number {
    font-family: 'Cinzel', serif;
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    color: var(--gold-dim);
    margin-bottom: 0.6rem;
  }

  .pillar h3 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 1.3rem;
    color: var(--gold-light);
    margin-bottom: 0.6rem;
  }

  .pillar p {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.7;
  }

  /* ---- WHAT WE ARE ---- */
  .what-we-are {
    background: var(--mid);
    text-align: center;
  }

  .what-we-are h2 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    margin-bottom: 1.5rem;
    color: var(--text);
  }

  .what-we-are h2 em { color: var(--gold); font-style: italic; }

  .what-we-are .lead {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.2rem;
    color: var(--text-dim);
    max-width: 700px;
    margin: 0 auto 4rem;
    line-height: 1.8;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 3rem;
  }

  .feature {
    padding: 3rem 2rem;
    background: var(--surface);
    text-align: left;
    position: relative;
    transition: background 0.3s;
  }

  .feature:hover { background: #2a2418; }

  .feature-icon {
    width: 36px;
    height: 36px;
    margin-bottom: 1.5rem;
    color: var(--gold);
  }

  .feature h3 {
    font-family: 'Cinzel', serif;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .feature p {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.8;
  }

  /* ---- CHARITY ---- */
  .charity {
    background: var(--deep);
    overflow: hidden;
  }

  .charity-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .charity-content h2 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1.5rem;
    color: var(--text);
    line-height: 1.2;
  }

  .charity-content h2 em { color: var(--gold); font-style: italic; }

  .charity-content p {
    font-size: 0.95rem;
    color: var(--text-dim);
    line-height: 1.9;
    margin-bottom: 1.4rem;
  }

  .charity-link {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    color: var(--gold);
    text-decoration: none;
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-top: 1rem;
    transition: gap 0.3s;
  }

  .charity-link:hover { gap: 1.4rem; }

  .charity-link::after { content: '→'; }

  .charity-visual {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .stat-card {
    padding: 2.5rem;
    border: 1px solid rgba(201,168,76,0.2);
    background: rgba(201,168,76,0.03);
    position: relative;
    overflow: hidden;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: linear-gradient(to bottom, var(--gold), var(--irish-green-light));
  }

  .stat-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3rem;
    color: var(--gold);
    font-weight: 300;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* ---- MEETINGS ---- */
  .meetings {
    background: var(--dark);
    text-align: center;
  }

  .meetings h2 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
    color: var(--text);
  }

  .meetings h2 em { color: var(--gold); font-style: italic; }

  .meetings .lead {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    color: var(--text-dim);
    font-size: 1.1rem;
    max-width: 580px;
    margin: 0 auto 4rem;
    line-height: 1.8;
  }

  .meetings-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    max-width: 900px;
    margin: 0 auto 4rem;
  }

  .meeting-card {
    background: var(--surface);
    padding: 2.5rem 1.5rem;
    position: relative;
    transition: background 0.3s;
  }

  .meeting-card:hover { background: #2a2418; }

  .meeting-icon {
    width: 32px;
    height: 32px;
    color: var(--gold);
    margin: 0 auto 1.2rem;
  }

  .meeting-card h3 {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: var(--gold-light);
    margin-bottom: 0.8rem;
  }

  .meeting-card p {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.7;
  }

  .venue-box {
    max-width: 600px;
    margin: 0 auto;
    border: 1px solid rgba(201,168,76,0.25);
    padding: 2.5rem;
    background: rgba(201,168,76,0.03);
    text-align: center;
  }

  .venue-box h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    color: var(--gold);
    margin-bottom: 0.6rem;
  }

  .venue-box p {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.7;
  }

  .venue-box .venue-sub {
    font-family: 'Cinzel', serif;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    color: var(--gold-dim);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  /* ---- IRISH HERITAGE ---- */
  .heritage {
    background: var(--mid);
    border-top: 1px solid rgba(201,168,76,0.1);
  }

  .heritage-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .heritage-content h2 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    margin-bottom: 1.5rem;
    color: var(--text);
    line-height: 1.25;
  }

  .heritage-content h2 em { color: var(--gold); font-style: italic; }

  .heritage-content p {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.9;
    margin-bottom: 1.2rem;
  }

  .heritage-badges {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .badge {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 1.2rem 1.5rem;
    background: rgba(26,74,46,0.12);
    border: 1px solid rgba(42,122,74,0.2);
    transition: border-color 0.3s;
  }

  .badge:hover { border-color: rgba(42,122,74,0.5); }

  .badge-dot {
    width: 10px;
    height: 10px;
    background: var(--irish-green-light);
    flex-shrink: 0;
    border-radius: 50%;
  }

  .badge p {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.5;
  }

  .badge strong {
    display: block;
    font-family: 'Cinzel', serif;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--irish-green-light);
    margin-bottom: 0.2rem;
    font-weight: 400;
  }

  /* ---- CONTACT ---- */
  .contact {
    background: var(--dark);
    text-align: center;
    border-top: 1px solid rgba(201,168,76,0.1);
  }

  .contact h2 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--text);
    margin-bottom: 1rem;
  }

  .contact h2 em { color: var(--gold); font-style: italic; }

  .contact .lead {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    color: var(--text-dim);
    font-size: 1.1rem;
    max-width: 560px;
    margin: 0 auto 3.5rem;
    line-height: 1.8;
  }

  .contact-form {
    max-width: 500px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    text-align: left;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-field label {
    font-family: 'Cinzel', serif;
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    color: var(--gold-dim);
    text-transform: uppercase;
  }

  .form-field input,
  .form-field textarea {
    background: var(--surface);
    border: 1px solid rgba(201,168,76,0.2);
    color: var(--text);
    padding: 0.9rem 1rem;
    font-family: 'Lato', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    transition: border-color 0.3s;
    resize: vertical;
    outline: none;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    border-color: var(--gold);
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--text-dim);
    opacity: 0.5;
  }

  .form-submit {
    margin-top: 0.5rem;
    text-align: center;
  }

  .lodge-name-footer {
    margin-top: 6rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(201,168,76,0.1);
    text-align: center;
  }

  .lodge-name-footer p {
    font-family: 'Cinzel', serif;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    color: var(--gold-dim);
    text-transform: uppercase;
    line-height: 2;
  }

  /* ---- RESPONSIVE ---- */
  @media (max-width: 768px) {
    nav { padding: 1.2rem 1.5rem; }
    .nav-links { display: none; }
    .philosophy-grid,
    .charity-inner,
    .heritage-grid { grid-template-columns: 1fr; gap: 3rem; }
    .features-grid,
    .meetings-grid { grid-template-columns: 1fr; }
  }

  /* ---- ACCESSIBILITY WIDGET ---- */
  .a11y-toggle {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.8rem;
  }

  .a11y-btn {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--gold);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    transition: background 0.3s, transform 0.2s;
    flex-shrink: 0;
  }

  .a11y-btn:hover { background: var(--gold-light); transform: scale(1.08); }
  .a11y-btn svg { width: 26px; height: 26px; color: var(--dark); }

  .a11y-panel {
    background: var(--surface);
    border: 1px solid rgba(201,168,76,0.3);
    padding: 1.5rem;
    width: 240px;
    display: none;
    flex-direction: column;
    gap: 0.8rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.6);
  }

  .a11y-panel.open { display: flex; }

  .a11y-panel-title {
    font-family: 'Cinzel', serif;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
